# Production environment template for first deploy.
# WARNING: do not commit real secrets/tokens/passwords.

APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000
POSTGRES_DB=avito_watcher
POSTGRES_USER=avito_watcher
POSTGRES_PASSWORD=<strong-db-password>
# docker-compose.prod.yml postgres service reads POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD.
# DATABASE_URL is used by app runtime and must be written as a full explicit URL.
# Do not rely on ${POSTGRES_USER}/${POSTGRES_PASSWORD}/${POSTGRES_DB} expansion inside DATABASE_URL
# unless you verified it end-to-end via `docker compose ... config` and app runtime startup.
# If DB password contains special characters, URL-encode it in DATABASE_URL.
DATABASE_URL=postgresql+psycopg://avito_watcher:<strong-db-password>@postgres:5432/avito_watcher
REDIS_URL=redis://<redis_host>:6379/0
API_KEY=<strong-random-api-key>
ADMIN_UI_ENABLED=true

# --- Core first-deploy stance (AI out of critical alert path) ---
SCORING_ENABLED=false
LLM_PROVIDER=off
LLM_SHADOW_MODE=true
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SEC=60
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SEC=1.0
LLM_PROMPT_VERSION=listing-summary-v1

# Optional DeepSeek API shadow mode after core smoke
# DeepSeek uses the existing openai_compatible provider.
# Do not use LLM_PROVIDER=deepseek unless a dedicated provider is added later.
# SCORING_ENABLED=true
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-pro
# LLM_API_KEY=<deepseek-api-key>
# LLM_SHADOW_MODE=true
# LLM_TIMEOUT_SEC=20
# LLM_MAX_RETRIES=2
# LLM_RETRY_DELAY_SEC=1.0
# LLM_PROMPT_VERSION=listing-summary-v1

# --- Scraping/runtime defaults for first production rollout ---
SCRAPE_HEADLESS=true
SCRAPE_HUMANIZE=false
SCRAPE_TIMEOUT_MS=45000
SCRAPE_CONCURRENCY=2
SCRAPE_MAX_PAGES=3
SCRAPE_CARDS_PER_PAGE_LIMIT=30
SCRAPE_STOP_ON_DUPLICATE_PAGE=true
SCRAPE_PAGE_DELAY_MS=5000
SCRAPE_PAGE_JITTER_MS=3000
SCRAPE_ENRICH_MISSING_PUBLISHED_AT=true
SCRAPE_ENRICH_ITEM_PAGE_DETAILS=false
SCRAPE_ITEM_PAGE_DELAY_MS=1500
SCRAPE_ITEM_PAGE_JITTER_MS=1000
SCRAPE_ITEM_PAGE_LIMIT_PER_RUN=10
SCRAPE_DEBUG_DUMP_HTML=false
SCRAPE_DEBUG_DUMP_DIR=./data/debug_html
SCRAPE_DEBUG_DUMP_MAX_BYTES=2000000
SCRAPE_PREFERRED_ENGINE=camoufox
SCRAPE_ALLOWED_ENGINES=camoufox
SCRAPE_NODRIVER_BROWSER_EXECUTABLE_PATH=
SCRAPE_TIMEOUT_RETRY_ONCE=false
SCRAPE_TIMEOUT_RETRY_DELAY_MS=300
SCRAPE_CAMOUFOX_RETRY_ON_DRIVER_CRASH=true

# --- Proxy pool (recommended for Avito access) ---
# 2-3 mobile RU proxies in a comma-separated list.
PROXY_URLS=http://<user1>:<pass1>@<host1>:<port1>,http://<user2>:<pass2>@<host2>:<port2>,http://<user3>:<pass3>@<host3>:<port3>
PROXY_QUARANTINE_SECONDS=300

# --- Alerts ---
# First production default: JSONL-only audit trail.
ALERT_CHANNELS=jsonl
JSONL_OUTBOX_ENABLED=true
JSONL_OUTBOX_PATH=./data/alerts.jsonl
ALERT_DELIVERY_BULK_GUARD_ENABLED=true
ALERT_DELIVERY_MAX_NEW_PER_CYCLE=50

# Optional Telegram channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Google Sheets webhook channel (enable only with real values)
GOOGLE_SHEETS_WEBHOOK_ENABLED=false
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/<deployment-id>/exec
# GOOGLE_SHEETS_WEBHOOK_SECRET=<google-sheets-webhook-secret>
GOOGLE_SHEETS_WEBHOOK_TIMEOUT_SEC=15

# Optional email channel (enable only with real values)
EMAIL_ENABLED=false
# SMTP_HOST=smtp.example.com
SMTP_PORT=465
# SMTP_USERNAME=<smtp-username>
# SMTP_PASSWORD=<smtp-password>
# EMAIL_FROM=alerts@example.com
# EMAIL_TO=ops@example.com

# Worker lock file path
MONITOR_WORKER_LOCK_PATH=./data/monitor_worker.lock
