APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/avito_watcher
REDIS_URL=redis://localhost:6379/0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
SCORING_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_CHANNELS=jsonl,email,google_sheets

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

JSONL_OUTBOX_ENABLED=true
JSONL_OUTBOX_PATH=./data/alerts.jsonl

GOOGLE_SHEETS_WEBHOOK_ENABLED=false
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
GOOGLE_SHEETS_WEBHOOK_TIMEOUT_SEC=15
SCRAPE_HEADLESS=true
SCRAPE_HUMANIZE=false
SCRAPE_TIMEOUT_MS=45000
SCRAPE_CONCURRENCY=2

# ---------------------------------------------------------------------------
# Proxy Configuration (required to bypass Avito IP blocks)
# ---------------------------------------------------------------------------
# Comma-separated mobile RU proxy URLs. Leave empty to run without proxies.
# Format: http://user:pass@host:port,http://user:pass@host2:port2
# Recommended providers: mobileproxy.space, proxywing.com
PROXY_URLS=

SCRAPE_PREFERRED_ENGINE=auto
